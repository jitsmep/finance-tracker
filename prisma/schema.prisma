generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id        String   @id @default(cuid())
  pin       String   // hashed PIN
  createdAt DateTime @default(now())
}

model Category {
  id           String        @id @default(cuid())
  deviceId     String
  name         String
  icon         String        @default("📌")
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  budgets      Budget[]

  @@unique([deviceId, name])
}

model Transaction {
  id         String   @id @default(cuid())
  deviceId   String
  type       String   // "income" | "expense"
  amount     Float
  date       DateTime
  note       String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Budget {
  id         String   @id @default(cuid())
  deviceId   String
  month      Int
  year       Int
  limit      Float
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([deviceId, categoryId, month, year])
}

model Settings {
  id           String   @id // deviceId is the id
  currencyCode String   @default("USD")
  updatedAt    DateTime @updatedAt
}

model Asset {
  id        String   @id @default(cuid())
  deviceId  String
  name      String
  value     Float
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Liability {
  id        String   @id @default(cuid())
  deviceId  String
  name      String
  amount    Float
  interest  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockPortfolio {
  id        String   @id @default(cuid())
  deviceId  String
  ticker    String
  shares    Float
  buyPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
