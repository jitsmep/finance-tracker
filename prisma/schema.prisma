generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  icon         String        @default("📌")
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id         String   @id @default(cuid())
  type       String   // "income" | "expense"
  amount     Float
  date       DateTime
  note       String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Budget {
  id         String   @id @default(cuid())
  month      Int
  year       Int
  limit      Float
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, month, year])
}

model Settings {
  id           String   @id @default("default")
  currencyCode String   @default("USD")
  updatedAt    DateTime @updatedAt
}

// --- NEW MODELS FOR NET WORTH & PORTFOLIO ---

model Asset {
  id          String   @id @default(cuid())
  name        String   // e.g., "House", "Savings Account", "Rolex"
  value       Float    // Current estimated value
  type        String   // e.g., "Real Estate", "Cash", "Vehicle"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Liability {
  id          String   @id @default(cuid())
  name        String   // e.g., "Car Loan", "Credit Card", "Mortgage"
  amount      Float    // How much you currently owe
  interest    Float?   // Optional interest rate
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StockPortfolio {
  id          String   @id @default(cuid())
  ticker      String   // e.g., "AAPL", "TSLA", "VOO"
  shares      Float    // Number of shares owned
  buyPrice    Float    // Average price paid per share
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
